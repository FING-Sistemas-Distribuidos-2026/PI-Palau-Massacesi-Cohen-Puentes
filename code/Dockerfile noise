# 1. Usamos una imagen oficial de Python ligera (Slim) basada en Debian
FROM python:3.11-slim

# 2. Establecemos el directorio de trabajo dentro del contenedor
WORKDIR /app

# 3. Copiamos primero el archivo de dependencias para aprovechar la caché de Docker
COPY requirements-noise.txt .

# 4. Instalamos las librerías de Python
RUN pip install --no-cache-dir -r requirements-noise.txt

# 5. Copiamos el resto del código fuente (tu script procesador.py)
COPY noise.py .

# 6. El comando que se ejecutará por defecto cuando Kubernetes levante el Job
CMD ["python", "noise.py"]